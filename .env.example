# ============================================
# 小米 MiMo API 配置
# ============================================
# 请将此文件复制为 .env 并填入你的 API Key
# cp .env.example .env

# API Key（从小米 MiMo 控制台获取）
# Token Plan 用户使用 tp- 开头的 Key
MIMO_API_KEY=your_mimo_api_key_here

# API 地址
# Token Plan 套餐专属 URL（使用 tp- 开头的 Key 时使用此地址）
# 中国集群: https://token-plan-cn.xiaomimimo.com/v1
# 新加坡集群: https://token-plan-sgp.xiaomimimo.com/v1
# 欧洲集群: https://token-plan-ams.xiaomimimo.com/v1
# 普通 API Key（非 tp- 开头）使用: https://api.xiaomimimo.com/v1
MIMO_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1

# ASR 模型配置
# 可选模型:
#   - mimo-v2.5-asr     (推荐) 专用于语音识别
#   - mimo-v2.5         通用多模态模型，支持语音
#   - mimo-v2.5-pro     增强版多模态模型
#   - mimo-v2-pro       旧版增强模型
#   - mimo-v2-omni      全功能模型
ASR_MODEL=mimo-v2.5-asr
ASR_LANGUAGE=zh

# 情绪分析模型配置
EMOTION_MODEL=mimo-v2.5-pro

# 是否启用真实 ASR
# true = 使用小米 MiMo ASR 进行真实转写
# false = 使用模拟数据（不需要 API Key）
ENABLE_REAL_ASR=true

# 是否启用真实说话人分离
ENABLE_REAL_DIARIZATION=true

# 是否启用真实情绪分析
ENABLE_REAL_EMOTION=true

# 是否启用真实通话总结
ENABLE_REAL_SUMMARY=true

# 日志级别: debug, info, warn, error
LOG_LEVEL=info

# 服务端口
PORT=3000
