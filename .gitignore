# ============================================
# Node.js
# ============================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ============================================
# 环境配置（包含敏感信息，不要提交）
# ============================================
.env
.env.local
.env.*.local

# ============================================
# 上传文件（运行时生成）
# ============================================
uploads/
*.converted.mp3

# ============================================
# 日志文件
# ============================================
logs/
*.log

# ============================================
# 缓存文件
# ============================================
cache/
*.cache

# ============================================
# 数据文件（可选，如需版本控制可注释掉）
# ============================================
data/

# ============================================
# IDE 和编辑器
# ============================================
.idea/
.vscode/
*.swp
*.swo
*~

# ============================================
# 系统文件
# ============================================
.DS_Store
Thumbs.db
desktop.ini

# ============================================
# 构建输出
# ============================================
dist/
build/
*.tsbuildinfo

# ============================================
# 测试覆盖率
# ============================================
coverage/

# ============================================
# 临时文件
# ============================================
tmp/
temp/
*.tmp
